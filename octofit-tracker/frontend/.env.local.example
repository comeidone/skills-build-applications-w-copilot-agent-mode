# OctoFit Tracker Frontend Environment Configuration
# Copy this file to .env.local and fill in your actual Codespace name

# GitHub Codespace name for API URL construction
# Example: VITE_CODESPACE_NAME=verbose-space-train-5vj6v7pvv49fvx7g
# Leave empty for localhost development
VITE_CODESPACE_NAME=your-codespace-name-here
